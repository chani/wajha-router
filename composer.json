{
    "name": "chani/wajha",
    "description": "A fast, lightweight HTTP router for PHP 8.3+ combining O(1) static maps and bucketed PCRE2 regex evaluation.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Jean Bruenn"
	}
    ],
    "autoload": {
        "psr-4": {
            "Safi\\Wajha\\": "src/"
        }
    },
    "autoload-dev": {
	"psr-4": {
            "Safi\\Wajha\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "altorouter/altorouter": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "nikic/fast-route": "^1.3",
        "phpstan/phpstan": "^2.2",
        "phpunit/phpunit": "^13.2",
        "phroute/phroute": "^2.2",
        "symfony/routing": "^8.1"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
